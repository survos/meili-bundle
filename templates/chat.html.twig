{% extends "@SurvosMeili/base.html.twig" %}

{% set ctrl = '@survos/meili-bundle/chat' %}

{% block title %}Chat · {{ baseIndexName }}{% endblock %}

{#{% block stylesheets %}#}
{#  {{ parent() }}#}
{#{% endblock %}#}

{% block body %}

<div class="chat-layout" {{ stimulus_controller(ctrl, {
    streamUrl:    streamUrl,
    templateUrl:  templateUrl,
    schemaUrl:    schemaUrl|default(''),
    indexName:    indexName,
    meiliHost:    meiliHost,
    meiliApiKey:  meiliApiKey,
    primaryKey:   primaryKey|default('id'),
    iconsMap:     {'tabler:external-link': ux_icon('tabler:external-link'), 'json': ux_icon('json')},
    initialQuery: initialQuery|default(''),
    debugMode:    false,
    debugContext: {
      workspace: workspace,
      chatWorkspace: chatWorkspace,
      workspaceTemplate: workspaceTemplate,
      workspaceCfg: workspaceCfg,
      livePrompts: livePrompts,
      indexSettings: indexSettings,
      liveIndexSettings: liveIndexSettings,
      chatApiKeyPresent: chatApiKeyPresent,
      chatKeyDebug: chatKeyDebug,
    },
}) }}>

  {# ── Left panel: conversation ── #}
  <div class="chat-panel card card-flat">

    {# Header #}
    <div class="chat-panel-header">
      <div class="d-flex align-items-center gap-2">
        <span class="avatar avatar-sm avatar-rounded bg-primary-lt text-primary">
          {{ ux_icon('mdi:robot-outline', {width: '16px', height: '16px'}) }}
        </span>
        <div class="small">
          <div class="fw-semibold lh-1">{{ curatorName }}</div>
          <div class="text-muted" style="font-size:.65rem">{{ baseIndexName }}</div>
        </div>
    </div>
    <div class="ms-auto d-flex align-items-center gap-2">
      <div class="form-check form-switch mb-0">
        <input class="form-check-input" type="checkbox" id="debugToggle" {{ stimulus_target(ctrl, 'debugToggle') }}>
        <label class="form-check-label small" for="debugToggle">Debug</label>
      </div>
      <button class="btn btn-sm btn-ghost-secondary"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#chatDebugPanel"
              title="Toggle debug info">
        {{ ux_icon('tabler:bug', {width: '14px', height: '14px'}) }}
      </button>
      {# Mobile-only button to open detail panel #}
      <button class="btn btn-sm btn-ghost-secondary d-lg-none detail-panel-open-btn"
              type="button"
              data-bs-toggle="offcanvas"
              data-bs-target="#detailOffcanvas"
              aria-controls="detailOffcanvas"
              title="Show detail panel"
              {{ stimulus_target(ctrl, 'detailOpenBtn') }}>
        {{ ux_icon('tabler:clipboard-text', {width: '14px', height: '14px'}) }}
      </button>
      <button class="btn btn-sm btn-ghost-secondary"
              {{ stimulus_action(ctrl, 'clearHistory') }}
              title="Clear conversation">
        {{ ux_icon('tabler:trash', {width: '14px', height: '14px'}) }}
      </button>
    </div>
    </div>

    {# Debug panel: show prompt config #}
    <div class="chat-debug-prompt collapse" id="chatDebugPanel" style="font-size: .7rem;">
      <div class="chat-debug-prompt-label">Prompt Config</div>
      <pre class="chat-debug-pre small mb-1" style="max-height: 150px; overflow-y: auto; font-size: .65rem;">{{ livePrompts|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
      <div class="chat-debug-prompt-label">Workspace: <code>{{ workspace }}</code></div>
      <div class="chat-debug-prompt-label">Index: <code>{{ indexName }}</code></div>
      <div class="chat-debug-prompt-label">Search Key: {{ meiliApiKey ? 'present' : 'missing' }} | Chat Key: {{ chatApiKeyPresent ? 'present' : 'missing' }}</div>
    </div>

    {% if livePrompts is null %}
      <div class="alert alert-warning mb-0">
        Could not retrieve prompts from workspace <code>{{ workspace }}</code>.
        Run <code>bin/console meili:settings:update --chat --keys --force</code>.
      </div>
    {% endif %}

    {# Messages #}
    <div class="chat-messages" {{ stimulus_target(ctrl, 'messages') }}>

      {# Welcome bubble #}
      <div class="chat-welcome">
        <div class="avatar avatar-md avatar-rounded bg-primary-lt text-primary mb-3">
          {{ ux_icon('mdi:robot-outline', {width: '20px', height: '20px'}) }}
        </div>
        <p class="fw-semibold mb-1">Hi, I'm <strong>{{ curatorName }}</strong></p>
        <p class="text-muted small mb-3">
          Our collection contains <strong>{{ collectionOverview.documents ?? 0 }}</strong> items. Ask me anything.
        </p>
        {% if welcomeExamples|default([])|length > 0 %}
          <p class="text-muted small mb-2">Try asking:</p>
          <div class="d-flex flex-wrap gap-1">
            {% for example in welcomeExamples|slice(0,4) %}
              <button class="btn btn-sm btn-outline-secondary chat-suggestion"
                      {{ stimulus_action(ctrl, 'suggest') }}>
                {{ example }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

    </div>

    {# Typing indicator (hidden by default) #}
    <div class="chat-typing d-none" {{ stimulus_target(ctrl, 'typing') }}>
      <span></span><span></span><span></span>
    </div>

    {# Input area #}
    <div class="chat-input-area">
      <div class="chat-input-box">
        <textarea
          rows="1"
          placeholder="Ask a question…"
          class="chat-textarea"
          {{ stimulus_target(ctrl, 'input') }}
          {{ stimulus_action(ctrl, 'keydown', 'keydown') }}
          {{ stimulus_action(ctrl, 'autoResize', 'input') }}
        ></textarea>
        <button class="btn btn-primary btn-sm chat-send-btn"
                {{ stimulus_action(ctrl, 'send') }}
                {{ stimulus_target(ctrl, 'sendBtn') }}>
          {{ ux_icon('tabler:send', {width: '16px', height: '16px'}) }}
        </button>
      </div>
      <div class="chat-input-hint text-muted">
        Press <kbd>Enter</kbd> to send · <kbd>Shift+Enter</kbd> for new line
      </div>
    </div>

  </div>

  {# ── Right panel: detail view (offcanvas on mobile, inline on desktop) — collapsible #}
  <div class="offcanvas offcanvas-end detail-panel card card-flat"
       tabindex="-1"
       id="detailOffcanvas"
       aria-labelledby="detailOffcanvasLabel"
       data-bs-scroll="true"
       style="width: 350px;"
       {{ stimulus_target(ctrl, 'detailPanel') }}>

    <div class="detail-panel-header">
      <span class="fw-semibold detail-panel-title"
            id="detailOffcanvasLabel"
            {{ stimulus_target(ctrl, 'detailTitle') }}
            style="font-size:.9rem">Detail view</span>
      <span class="badge bg-secondary-lt text-secondary ms-auto detail-panel-badge"
            {{ stimulus_target(ctrl, 'detailBadge') }}
            style="font-size:.7rem">Select a result</span>
      {# Close button — only shown when rendered as offcanvas on mobile #}
      <button type="button"
        class="btn-close detail-panel-close ms-2"
        aria-label="Close"
        {{ stimulus_action(ctrl, 'closeDetail') }}></button>
    </div>

    <div class="detail-panel-body" {{ stimulus_target(ctrl, 'detailBody') }}>
      <div class="detail-empty">
        {{ ux_icon('tabler:clipboard-text', {width: '32px', height: '32px', class: 'text-muted mb-2'}) }}
        <p class="text-muted small">Click "Show details" on a result to view it here</p>
      </div>
    </div>

  </div>

</div>

{% endblock %}
