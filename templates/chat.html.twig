{% extends "@SurvosMeili/base.html.twig" %}

{% set ctrl = 'survos--meili-bundle--chat' %}

{% block title %}Chat · {{ baseIndexName }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
{% endblock %}

{% block body %}

<div class="chat-layout" {{ stimulus_controller(ctrl, {
    streamUrl:   streamUrl,
    templateUrl: templateUrl,
    schemaUrl:   schemaUrl|default(''),
    indexName:   indexName,
    meiliHost:   meiliHost,
    meiliApiKey: meiliApiKey,
    primaryKey:  primaryKey|default('id'),
}) }}>

  {# ── Left panel: conversation ── #}
  <div class="chat-panel card card-flat">

    {# Header #}
    <div class="chat-panel-header">
      <div class="d-flex align-items-center gap-2">
        <span class="avatar avatar-sm avatar-rounded bg-primary-lt text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
        </span>
        <div>
          <div class="fw-semibold lh-1" style="font-size:.9rem">{{ curatorName }}</div>
          <div class="text-muted" style="font-size:.75rem">{{ baseIndexName }}</div>
        </div>
      </div>
      <button class="btn btn-sm btn-ghost-secondary ms-auto"
              {{ stimulus_action(ctrl, 'clearHistory') }}
              title="Clear conversation">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
      </button>
    </div>

    {# Messages #}
    <div class="chat-messages" {{ stimulus_target(ctrl, 'messages') }}>

      {# Welcome bubble #}
      <div class="chat-welcome">
        <div class="avatar avatar-md avatar-rounded bg-primary-lt text-primary mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
        </div>
        <p class="fw-semibold mb-1">Hi, I'm <strong>{{ curatorName }}</strong></p>
        <p class="text-muted small mb-3">
          Our collection contains <strong>{{ collectionOverview.documents ?? 0 }}</strong> items. Ask me anything.
        </p>
        {% if welcomeExamples|default([])|length > 0 %}
          <p class="text-muted small mb-2">Try asking:</p>
          <div class="d-flex flex-wrap gap-1">
            {% for example in welcomeExamples|slice(0,4) %}
              <button class="btn btn-sm btn-outline-secondary chat-suggestion"
                      {{ stimulus_action(ctrl, 'suggest') }}>
                {{ example }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

    </div>

    {# Typing indicator (hidden by default) #}
    <div class="chat-typing d-none" {{ stimulus_target(ctrl, 'typing') }}>
      <span></span><span></span><span></span>
    </div>

    {# Input area #}
    <div class="chat-input-area">
      <div class="chat-input-box">
        <textarea
          rows="1"
          placeholder="Ask a question…"
          class="chat-textarea"
          {{ stimulus_target(ctrl, 'input') }}
          {{ stimulus_action(ctrl, 'keydown', 'keydown') }}
          {{ stimulus_action(ctrl, 'autoResize', 'input') }}
        ></textarea>
        <button class="btn btn-primary btn-sm chat-send-btn"
                {{ stimulus_action(ctrl, 'send') }}
                {{ stimulus_target(ctrl, 'sendBtn') }}>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
        </button>
      </div>
      <div class="chat-input-hint text-muted">
        Press <kbd>Enter</kbd> to send · <kbd>Shift+Enter</kbd> for new line
      </div>
    </div>

  </div>

  {# ── Right panel: detail view ── #}
  <div class="detail-panel card card-flat">

    <div class="detail-panel-header" {{ stimulus_target(ctrl, 'detailHeader') }}>
      <span class="fw-semibold" style="font-size:.9rem">Detail view</span>
      <span class="badge bg-secondary-lt text-secondary ms-auto" style="font-size:.7rem">Select a result</span>
    </div>

    <div class="detail-panel-body" {{ stimulus_target(ctrl, 'detailBody') }}>
      <div class="detail-empty">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted mb-2"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/></svg>
        <p class="text-muted small">Click "Show details" on a result to view it here</p>
      </div>
    </div>

  </div>

</div>

{% endblock %}
