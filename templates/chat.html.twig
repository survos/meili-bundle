{#
  File: templates/chat.html.twig
  Variables:
    indexName      - Meilisearch index UID
    baseIndexName  - registry base name
    workspace      - workspace name
    workspaceCfg   - workspace config array
    chatWorkspace  - same as workspace (for nav)
    embedders      - array of embedder names (for nav)
    livePrompts    - prompts fetched live from Meilisearch (may be null)
    templateUrl    - JS-Twig hit template URL
    streamUrl      - POST endpoint for SSE stream
#}
{% extends "@SurvosMeili/base.html.twig" %}

{% block title %}Chat · {{ baseIndexName }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    body { background: #C4E0E5 !important; }

    /* ── two-column wrapper ── */
    .chat-page-row {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      padding: .75rem;
      /* 56px meili-header + 48px safety margin for Symfony toolbar in dev
         and browser chrome on mobile. */
      height: calc(100vh - 56px - 48px);
      overflow: hidden;
    }
    @media (min-width: 768px) {
      .chat-page-row {
        flex-direction: row;
      }
    }

    /* ── prompt debug panel ── */
    .chat-debug-panel {
      background: rgba(255,255,255,.7);
      border: 1px solid #dee2e6;
      border-radius: .5rem;
      font-size: .8rem;
      flex-shrink: 0;
    }
    .chat-debug-summary {
      cursor: pointer;
      padding: .5rem .75rem;
      font-weight: 600;
      color: #495057;
      user-select: none;
      list-style: none;
      display: flex;
      align-items: center;
      gap: .4rem;
    }
    .chat-debug-summary:hover { color: #0d6efd; }
    .chat-debug-summary::-webkit-details-marker { display: none; }
    .chat-debug-body {
      border-top: 1px solid #dee2e6;
      padding: .75rem;
      display: flex;
      flex-direction: column;
      gap: .75rem;
    }
    .chat-debug-prompt-label {
      font-size: .7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .05em;
      color: #6c757d; margin-bottom: .2rem;
    }
    .chat-debug-pre {
      background: #f8f9fa; border: 1px solid #e9ecef;
      border-radius: .375rem; font-size: .72rem;
      line-height: 1.5; margin: 0; padding: .5rem .75rem;
      white-space: pre-wrap; word-break: break-word;
    }

    /* ── chat column ── */
    .chat-col {
      flex: 0 0 100%;
      display: flex;
      flex-direction: column;
      background: rgba(255,255,255,.15);
      border-radius: .5rem;
      overflow: hidden;
      min-height: 0;
    }
    @media (min-width: 768px) {
      .chat-col { flex: 0 0 55%; max-width: 55%; }
    }

    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: .75rem .75rem 1rem;
      display: flex;
      flex-direction: column;
      gap: .5rem;
      scroll-padding-bottom: 1rem;
    }

    .chat-bubble {
      max-width: 88%;
      padding: .6rem .9rem;
      border-radius: 1rem;
      line-height: 1.5;
      word-break: break-word;
    }
    .chat-bubble.user {
      align-self: flex-end;
      background: #0d6efd; color: #fff;
      border-bottom-right-radius: .25rem;
    }
    .chat-bubble.assistant {
      align-self: flex-start;
      background: #fff; border: 1px solid #dee2e6;
      border-bottom-left-radius: .25rem;
    }
    .chat-bubble.welcome {
      max-width: 94%;
      background: linear-gradient(135deg, rgba(255,255,255,.98), rgba(240,248,250,.95));
      border: 1px solid rgba(82, 126, 135, .25);
      box-shadow: 0 .4rem 1rem rgba(58, 93, 100, .08);
    }
    .chat-welcome-title {
      font-size: 1rem;
      margin-bottom: .5rem;
    }
    .chat-welcome-meta {
      margin: .5rem 0 0;
      padding-left: 1.1rem;
    }
    .chat-welcome-meta li,
    .chat-welcome-examples li {
      margin-bottom: .25rem;
    }
    .chat-welcome-examples {
      margin: .6rem 0 0;
      padding-left: 1.1rem;
    }
    .chat-bubble.assistant.streaming::after {
      content: '▌'; animation: blink .7s step-end infinite;
    }
    @keyframes blink { 50% { opacity: 0; } }
    .chat-bubble.error {
      align-self: flex-start;
      background: #f8d7da; border: 1px solid #f5c2c7; color: #842029;
    }

    /* markdown inside assistant bubbles */
    .chat-bubble.assistant p { margin: 0 0 .4rem; }
    .chat-bubble.assistant p:last-child { margin-bottom: 0; }
    .chat-bubble.assistant ul, .chat-bubble.assistant ol { margin: 0 0 .4rem; padding-left: 1.3rem; }
    .chat-bubble.assistant img { max-width:100%; max-height:180px; object-fit:contain; border-radius:.3rem; margin:.2rem 0; display:block; }
    .chat-bubble.assistant a { color:#0d6efd; text-decoration:underline; }
    .chat-bubble.assistant strong { font-weight:600; }

    /* search progress note */
    .chat-search-note {
      font-size: .7rem; color: #6c757d; padding: .1rem .5rem; font-family: monospace;
    }
    .chat-search-note::before { content: '🔍 '; }

    /* sources block */
    .chat-sources { flex-shrink: 0; }
    .chat-sources summary {
      cursor: pointer; font-size: .78rem; color: #6c757d;
      user-select: none; padding: .15rem 0;
    }
    .chat-sources summary:hover { color: #0d6efd; }
    .chat-sources-json {
      background: #f8f9fa; border: 1px solid #dee2e6; border-radius: .375rem;
      font-size: .68rem; line-height: 1.4; max-height: 260px; overflow: auto;
      padding: .6rem; white-space: pre; word-break: normal;
    }
    .chat-sources-list { display: flex; flex-wrap: wrap; gap: .35rem; margin-top: .35rem; }
    .chat-sources-list .btn-show-detail {
      font-size: .72rem; padding: .2rem .5rem;
    }

    /* input row — sits above the Symfony debug toolbar in dev.
       padding-bottom uses a CSS env() fallback for mobile notches,
       with a minimum of 2.5rem to clear the toolbar. */
    .chat-input-row {
      display: flex; gap: .5rem;
      padding: .6rem .75rem;
      padding-bottom: max(.6rem, env(safe-area-inset-bottom, 0px));
      background: rgba(255,255,255,.85);
      backdrop-filter: blur(6px);
      border-top: 1px solid #dee2e6;
      border-radius: 0 0 .5rem .5rem;
      flex-shrink: 0;
      box-shadow: 0 -2px 8px rgba(0,0,0,.06);
    }
    .chat-input-row textarea {
      flex: 1; resize: none; border-radius: .75rem;
      border: 1px solid #ced4da; padding: .5rem .9rem;
      font-size: .95rem; line-height: 1.5;
      background: #fff;
      transition: border-color .15s;
    }
    .chat-input-row textarea:focus {
      outline: none;
      border-color: #0d6efd;
      box-shadow: 0 0 0 .15rem rgba(13,110,253,.15);
    }
    .chat-input-row button { align-self: flex-end; margin-bottom: .1rem; }

    /* ── detail panel column ── */
    .detail-col {
      flex: 1;
      display: flex;
      flex-direction: column;
      background: rgba(255,255,255,.6);
      border-radius: .5rem;
      overflow: hidden;
      min-height: 0;
    }
    .detail-col-header {
      padding: .5rem .75rem;
      font-size: .8rem; font-weight: 600; color: #6c757d;
      border-bottom: 1px solid #dee2e6; flex-shrink: 0;
    }
    .detail-col-body {
      flex: 1; overflow-y: auto; padding: .75rem;
    }
    .detail-col-empty {
      display: flex; align-items: center; justify-content: center;
      height: 100%; color: #adb5bd; font-size: .9rem; text-align: center;
    }
  </style>
{% endblock %}

{% block body %}

{# ── prompt debug panel (full width, above columns) ── #}
<details class="chat-debug-panel mx-2 mt-2" style="flex-shrink:0">
  <summary class="chat-debug-summary">
    {{ ux_icon('mdi:bug-outline') }}
    Prompt debug — <code>{{ workspace }}</code> · index <code>{{ indexName }}</code>
    {% if livePrompts is null %}<span class="badge bg-warning text-dark ms-2">Could not fetch live prompts</span>{% endif %}
  </summary>
  <div class="chat-debug-body">
    <div class="chat-debug-prompt">
      <div class="chat-debug-prompt-label">Chat key</div>
      <pre class="chat-debug-pre">status={{ chatKeyDebug.status ?? 'unknown' }}
source={{ chatKeyDebug.source ?? 'unknown' }}
keyUid={{ chatKeyDebug.keyUid ?? '(none)' }}
hasApiKey={{ chatKeyDebug.hasApiKey ?? false ? 'yes' : 'no' }}</pre>
      {% if not (chatKeyDebug.hasApiKey ?? false) %}
        <div class="alert alert-warning mb-0 mt-2">
          No scoped chat API key is available for <code>{{ indexName }}</code> / <code>{{ workspace }}</code>.
          Run <code>bin/console meili:settings:update --force</code> to create and register it.
        </div>
      {% endif %}
    </div>
    {% if livePrompts is null %}
      <div class="alert alert-warning mb-0">
        Could not retrieve prompts from workspace <code>{{ workspace }}</code>.
        Run <code>bin/console meili:settings:update --force</code>.
      </div>
    {% else %}
      {% set promptKeys = {system:'System', searchDescription:'Search description', searchQParam:'q param', searchFilterParam:'filter param', searchIndexUidParam:'index UID param'} %}
      {% for key, label in promptKeys %}
        {% if livePrompts[key] is defined and livePrompts[key] %}
          <div class="chat-debug-prompt">
            <div class="chat-debug-prompt-label">{{ label }}</div>
            <pre class="chat-debug-pre">{{ livePrompts[key] }}</pre>
          </div>
        {% endif %}
      {% endfor %}
      {% for key, value in livePrompts %}
        {% if key not in ['system','searchDescription','searchQParam','searchFilterParam','searchIndexUidParam'] and value %}
          <div class="chat-debug-prompt">
            <div class="chat-debug-prompt-label">{{ key }}</div>
            <pre class="chat-debug-pre">{{ value }}</pre>
          </div>
        {% endif %}
      {% endfor %}
    {% endif %}
  </div>
</details>

{# ── two-column layout ── #}
<div class="chat-page-row">

  {# ── LEFT: chat column ── #}
  <div class="chat-col shadow-sm">

    <div class="chat-messages" id="chat-messages">
      <div class="chat-bubble assistant welcome">
        <div class="chat-welcome-title">
          Hi, I'm <strong>{{ curatorName }}</strong>. Welcome to <strong>{{ (workspaceCfg.label ?? baseIndexName)|replace({'_':' ', '-':' '})|title }}</strong>.
        </div>
        <p>
          Our collection contains <strong>{{ collectionOverview.documents ?? 0 }}</strong> items
          {% if collectionOverview.overviewFacet is defined and collectionOverview.overviewFacet.values is defined and collectionOverview.overviewFacet.values %}
            , mostly
            {% for facet in collectionOverview.overviewFacet.values %}
              <strong>{{ facet.value }}</strong> ({{ facet.percentage|round(0, 'common') }}%){{ not loop.last ? ', ' : '' }}
            {% endfor %}
            across its {{ collectionOverview.overviewFacet.label }}
          {% endif %}.
        </p>
        {% if collectionOverview.locationFacet is defined and collectionOverview.locationFacet.values is defined and collectionOverview.locationFacet.values %}
          <p>
            Common physical locations include
            {% for facet in collectionOverview.locationFacet.values %}
              <strong>{{ facet.value }}</strong> ({{ facet.percentage|round(0, 'common') }}%){{ not loop.last ? ', ' : '' }}
            {% endfor %}.
          </p>
        {% endif %}
        {% if collectionOverview.summary is defined and collectionOverview.summary %}
          <p>{{ collectionOverview.summary }}</p>
        {% endif %}
        <p class="mb-1">You can ask me things like:</p>
        <ul class="chat-welcome-examples">
          {% for example in welcomeExamples|slice(0, 4) %}
            <li>{{ example }}</li>
          {% endfor %}
        </ul>
      </div>
    </div>

    <div class="chat-input-row">
      <textarea id="chat-input" rows="2" placeholder="Ask a question…" autofocus></textarea>
      <button id="chat-send" class="btn btn-primary btn-sm">Send</button>
    </div>

  </div>

  {# ── RIGHT: detail panel ── #}
  <div class="detail-col shadow-sm" id="detail-col">
    <div class="detail-col-header" id="detail-col-header">Detail</div>
    <div class="detail-col-body" id="detail-col-body">
      <div class="detail-col-empty" id="detail-col-empty">
        Click "Show details" on a result to view it here
      </div>
    </div>
  </div>

</div>
{% endblock body %}

{% block javascripts %}
  {{ parent() }}
  <script type="module">
  (async function () {
    // Dynamic import so a missing 'marked' package shows a clear UI error
    // instead of silently killing the whole script.
    // Install with: bin/console importmap:require marked
    let marked;
    try {
      ({ marked } = await import('marked'));
      marked.use({ breaks: true, gfm: true });
    } catch (e) {
      document.getElementById('chat-messages').innerHTML =
        `<div class="alert alert-danger m-3">
          <strong>Missing dependency:</strong> <code>marked</code> is not installed.<br>
          Run <code>bin/console importmap:require marked</code> then clear cache.<br>
          <small class="text-muted">${e.message}</small>
        </div>`;
      return;
    }

    const streamUrl   = {{ streamUrl|json_encode|raw }};
    const schemaUrl   = {{ schemaUrl|default(null)|json_encode|raw }};
    const templateUrl = {{ templateUrl|json_encode|raw }};
    const indexName   = {{ indexName|json_encode|raw }};
    const primaryKey  = {{ primaryKey|default('id')|json_encode|raw }};
    const meiliHost   = {{ meiliHost|json_encode|raw }};
    const meiliApiKey = {{ meiliApiKey|json_encode|raw }};

    // Populate the icons map for ux_icon() in JS-Twig hit templates.
    // Only include icons that are guaranteed to exist in the bundle's own icon set.
    // App-specific icons should be added in the app's own chat template override.
    window.__survosIconsMap = window.__survosIconsMap || {};
    Object.assign(window.__survosIconsMap, {{ {
        'tabler:external-link': ux_icon('tabler:external-link'),
        'json':                 ux_icon('si:json-duotone'),
    }|json_encode|raw }});

    const messages      = document.getElementById('chat-messages');
    const input         = document.getElementById('chat-input');
    const sendBtn       = document.getElementById('chat-send');
    const detailBody    = document.getElementById('detail-col-body');
    const detailHeader  = document.getElementById('detail-col-header');
    const detailEmpty   = document.getElementById('detail-col-empty');

    // ── conversation history ──
    const history = [];

    // ── JS-Twig engine ──
    // Single shared instance per page. createEngine() already wires ux_icon()
    // (via window.__survosIconsMap), stimulus_* and core functions/filters.
    // path() is wired async from the FOS routing module if js-twig-bundle is installed.
    let twigBlockName = null;
    let twigTemplateSource = null;
    let _engine = null;
    let _engineReady = null;

    async function ensureTwigEngine() {
      if (_engine) return _engine;
      try {
        const { createEngine } = await import('@tacman1123/twig-browser');
        _engine = createEngine();
        _engine.registerFunction('sais_encode', (url) =>
          btoa(url).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '')
        );
        // Wire path() from FOS routing if available (best-effort, async).
        _engineReady = import('@survos/js-twig/generated/fos_routes.js')
          .then(({ path }) => _engine.registerFunction('path', path))
          .catch(() => {});
      } catch (e) {
        console.warn('[chat] JS-Twig engine unavailable:', e);
      }
      return _engine;
    }

    async function ensureTemplate() {
      if (twigBlockName !== null && twigBlockName !== undefined) return twigBlockName;
      const engine = await ensureTwigEngine();
      if (!engine) return null;
      try {
        const { loadTemplateFromUrl } = await import('@tacman1123/twig-browser');
        const result = await loadTemplateFromUrl(engine, templateUrl);
        twigBlockName = result.blockName;
        twigTemplateSource = result.source;
      } catch (e) {
        console.error('[chat] template load failed:', e);
        twigBlockName = null;
      }
      return twigBlockName;
    }

    // ── fetch a document from Meilisearch by ID and render into detail panel ──
    async function showDetail(docId, label) {
      detailHeader.textContent = label || String(docId);
      detailBody.innerHTML = '<div class="text-muted small p-3">Loading…</div>';
      if (detailEmpty) detailEmpty.remove();

      // Fetch the full document from Meilisearch
      let doc;
      try {
        const headers = { 'Content-Type': 'application/json' };
        if (meiliApiKey) headers['Authorization'] = 'Bearer ' + meiliApiKey;
        const r = await fetch(`${meiliHost}/indexes/${indexName}/documents/${encodeURIComponent(docId)}`, { headers });
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        doc = await r.json();
      } catch (e) {
        detailBody.innerHTML = `<div class="alert alert-danger m-3">Could not fetch document <code>${docId}</code>: ${e.message}</div>`;
        return;
      }

      const engine    = await ensureTwigEngine();
      const blockName = await ensureTemplate();

      if (!engine || !blockName) {
        detailBody.innerHTML = renderFallback(null, doc, null);
        return;
      }

      try {
        // Mirror the context insta_controller passes to renderBlock so templates
        // work identically in both the search grid and the detail panel.
        const globals = {
          serverUrl:    meiliHost,
          serverApiKey: meiliApiKey,
          indexName:    indexName,
          _sc_modal:    '@survos/meili-bundle/json',
          debug:        false,
          details:      true,
          // Base URL patterns for linking to search/chat for a given index.
          // Templates replace INDEXNAME with the actual index uid.
          chatBaseUrl:   {{ path('meili_chat', {indexName: 'INDEXNAME', workspace: 'meili_assistant'})|json_encode|raw }},
          searchBaseUrl: {{ path('meili_insta', {indexName: 'INDEXNAME'})|json_encode|raw }},
        };
        const ctx = {
          hit:           doc,
          globals,
          _config:       { primaryKey: primaryKey, details: true },
          _score:        doc._rankingScore ?? null,
          _scoreDetails: doc._rankingScoreDetails ?? null,
          _isSemantic:   false,
          icons:         {},
          _sc_modal:     '@survos/meili-bundle/json',
          hints:         {},
          view:          {},
        };
        detailBody.innerHTML = engine.renderBlock(blockName, ctx);
      } catch (e) {
        console.error('[chat] render error:', e);
        detailBody.innerHTML = renderFallback(e, doc, twigTemplateSource);
      }
    }

    /** Render a loud error block + raw JSON + raw Twig source. */
    function renderFallback(err, doc, tmplSource) {
      const esc = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      let html = '';
      if (err) {
        html += `
          <div style="background:#dc3545;color:#fff;padding:.75rem 1rem;font-weight:700;font-size:.9rem;">
            ⚠ JS-Twig render error: ${esc(err.message)}
          </div>
          <pre style="background:#fff3f3;color:#7a0000;font-size:.7rem;padding:.75rem;margin:0;white-space:pre-wrap;border-bottom:2px solid #dc3545">${esc(err.stack ?? '')}</pre>`;
      } else {
        html += `<div class="alert alert-warning m-2 mb-0">JS-Twig engine or template unavailable — showing raw JSON.</div>`;
      }
      html += `
        <details open style="margin:0">
          <summary style="padding:.5rem .75rem;font-size:.75rem;font-weight:600;cursor:pointer;background:#f8f9fa">Raw JSON (document)</summary>
          <pre style="font-size:.7rem;padding:.75rem;margin:0;white-space:pre-wrap;max-height:300px;overflow:auto">${esc(JSON.stringify(doc, null, 2))}</pre>
        </details>`;
      if (tmplSource) {
        html += `
          <details style="margin:0;border-top:1px solid #dee2e6">
            <summary style="padding:.5rem .75rem;font-size:.75rem;font-weight:600;cursor:pointer;background:#f8f9fa">Raw Twig template (${esc(templateUrl)})</summary>
            <pre style="font-size:.7rem;padding:.75rem;margin:0;white-space:pre-wrap;max-height:300px;overflow:auto">${esc(tmplSource)}</pre>
          </details>`;
      }
      return html;
    }

    function scrollBottom() {
      messages.scrollTop = messages.scrollHeight;
    }

    function addBubble(role, text) {
      const div = document.createElement('div');
      div.className = 'chat-bubble ' + role;
      div.textContent = text;
      messages.appendChild(div);
      scrollBottom();
      return div;
    }

    /** Replace [id:xxx] tokens with "Show details" buttons. Run on raw markdown before parsing. */
    function injectDetailButtons(markdown) {
      return markdown.replace(/\[id:([^\]]+)\]/g, (_, docId) => {
        const id = docId.trim();
        // Emit an HTML span that marked will pass through as raw HTML
        return `<button class="btn btn-sm btn-outline-primary ms-1 py-0 px-2 chat-show-detail" data-doc-id="${id}" style="font-size:.75rem;vertical-align:middle">Show details</button>`;
      });
    }

    /** Render markdown into bubble; make links open in new tab. */
    function renderMarkdown(bubble, markdown) {
      bubble.classList.remove('streaming');
      const processed = injectDetailButtons(markdown);
      try {
        bubble.innerHTML = marked.parse(processed);
      } catch (e) {
        bubble.innerHTML = `<div class="alert alert-danger p-2 small">
          <strong>marked.parse() failed:</strong> ${e.message}<br>
          <code>templateUrl: ${templateUrl}</code>
        </div><pre class="small">${processed.slice(0, 500)}</pre>`;
        return;
      }
      bubble.querySelectorAll('a').forEach(a => {
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
      });
    }

    /** Build sources block with "Show details" button per document. */
    function addSourcesBlock(documents) {
      const docs = Array.isArray(documents) ? documents : Object.values(documents);
      if (!docs.length) return;

      const details = document.createElement('details');
      details.className = 'chat-sources';

      const summary = document.createElement('summary');
      summary.textContent = `${docs.length} source${docs.length > 1 ? 's' : ''} from Meilisearch`;
      details.appendChild(summary);

      // "Show details" buttons — store only the ID, fetch on click
      const list = document.createElement('div');
      list.className = 'chat-sources-list';
      docs.forEach((doc, i) => {
        const pk    = doc[primaryKey] ?? doc.meili_id ?? doc.id ?? doc.sku ?? doc.code ?? doc._id ?? Object.values(doc)[0] ?? i;
        const title = doc.title ?? doc.name ?? doc.label ?? `#${pk}`;
        const btn = document.createElement('button');
        btn.className = 'btn btn-sm btn-outline-primary btn-show-detail';
        btn.textContent = String(title).slice(0, 32);
        btn.title = `Show details for: ${title}`;
        btn.dataset.docId = String(pk);
        btn.dataset.docTitle = String(title).slice(0, 50);
        btn.addEventListener('click', () => showDetail(btn.dataset.docId, btn.dataset.docTitle));
        list.appendChild(btn);
      });
      details.appendChild(list);

      // Raw JSON (collapsed)
      const jsonDetails = document.createElement('details');
      jsonDetails.style.marginTop = '.35rem';
      const jsonSummary = document.createElement('summary');
      jsonSummary.style.cssText = 'font-size:.68rem;color:#6c757d;cursor:pointer';
      jsonSummary.textContent = 'Raw JSON';
      const pre = document.createElement('pre');
      pre.className = 'chat-sources-json';
      pre.textContent = JSON.stringify(docs, null, 2);
      jsonDetails.appendChild(jsonSummary);
      jsonDetails.appendChild(pre);
      details.appendChild(jsonDetails);

      messages.appendChild(details);

      // Auto-show first doc in detail panel (fetch by ID)
      if (docs.length > 0) {
        const first = docs[0];
        const pk    = first[primaryKey] ?? first.meili_id ?? first.id ?? first.sku ?? first.code ?? first._id ?? Object.values(first)[0];
        const title = first.title ?? first.name ?? first.label ?? `#${pk}`;
        showDetail(String(pk), String(title).slice(0, 50));
      }

      scrollBottom();
    }

    // ── debounced markdown re-render during streaming ──
    let renderTimer = null;
    function scheduleRender(bubble, text) {
      clearTimeout(renderTimer);
      renderTimer = setTimeout(() => renderMarkdown(bubble, text), 120);
    }

    async function send() {
      const text = input.value.trim();
      if (!text) return;

      input.value = '';
      input.disabled = true;
      sendBtn.disabled = true;

      addBubble('user', text);
      history.push({ role: 'user', content: text });

      const bubble = addBubble('assistant', '');
      bubble.classList.add('streaming');
      let reply = '';
      const toolCalls = {};

      try {
        const resp = await fetch(streamUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history, schemaUrl }),
        });

        if (!resp.ok) {
          bubble.classList.remove('streaming');
          bubble.classList.add('error');
          bubble.textContent = 'Error: ' + resp.status + ' ' + resp.statusText;
          return;
        }

        const reader  = resp.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });

          const parts = buffer.split('\n\n');
          buffer = parts.pop();

          for (const part of parts) {
            for (const line of part.split('\n')) {
              if (!line.startsWith('data:')) continue;
              const data = line.slice(5).trim();
              if (data === '[DONE]') continue;
              try {
                const parsed = JSON.parse(data);

                // Accumulate tool call fragments
                for (const tc of parsed?.choices?.[0]?.delta?.tool_calls ?? []) {
                  const idx = tc.index ?? 0;
                  if (!toolCalls[idx]) toolCalls[idx] = { id: '', name: '', args: '' };
                  if (tc.id)                  toolCalls[idx].id   = tc.id;
                  if (tc.function?.name)      toolCalls[idx].name = tc.function.name;
                  if (tc.function?.arguments) toolCalls[idx].args += tc.function.arguments;
                }

                if (parsed?.choices?.[0]?.finish_reason === 'tool_calls') {
                  for (const tc of Object.values(toolCalls)) {
                    let args = {};
                    try { args = JSON.parse(tc.args); } catch (_) {}

                    if (tc.name === '_meiliSearchProgress') {
                      try {
                        const params = JSON.parse(args.function_parameters ?? '{}');
                        if (params.index_uid) {
                          const note = document.createElement('div');
                          note.className = 'chat-search-note';
                          note.textContent = `${params.index_uid}${params.q ? ' · q: "' + params.q + '"' : ''}`;
                          messages.appendChild(note);
                          scrollBottom();
                        }
                      } catch (_) {}

                    } else if (tc.name === '_meiliSearchSources') {
                      addSourcesBlock(args.documents ?? args);

                    } else if (tc.name === '_meiliAppendConversationMessage') {
                      const msg = { role: args.role };
                      if (args.tool_calls)    msg.tool_calls    = args.tool_calls;
                      if (args.content)       msg.content       = args.content;
                      if (args.tool_call_id)  msg.tool_call_id  = args.tool_call_id;
                      history.push(msg);
                    }
                  }
                }

                // Content delta: update plain text while streaming,
                // schedule a markdown render every ~120ms so it feels live
                const rawDelta = parsed?.choices?.[0]?.delta?.content ?? '';
                const delta = typeof rawDelta === 'string' ? rawDelta
                            : (rawDelta !== null && rawDelta !== undefined ? JSON.stringify(rawDelta) : '');
                if (delta) {
                  reply += delta;
                  if (bubble.classList.contains('streaming')) {
                    // Render markdown incrementally with debounce
                    bubble.classList.add('streaming'); // re-add (renderMarkdown removes it)
                    scheduleRender(bubble, reply);
                    scrollBottom();
                  }
                }

                if (parsed?.error) {
                  bubble.classList.add('error');
                  const errObj = parsed.error;
                  bubble.textContent = typeof errObj === 'string' ? errObj
                    : (errObj?.message ?? JSON.stringify(errObj));
                }
              } catch (_) {}
            }
          }
        }
      } catch (err) {
        bubble.classList.add('error');
        bubble.textContent = 'Connection error: ' + err.message;
      } finally {
        clearTimeout(renderTimer);
        bubble.classList.remove('streaming');
        if (reply) {
          renderMarkdown(bubble, reply);
          history.push({ role: 'assistant', content: reply });
        }
        input.disabled = false;
        sendBtn.disabled = false;
        input.focus();
        scrollBottom();
      }
    }

    sendBtn.addEventListener('click', send);
    input.addEventListener('keydown', e => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
    });

    // "Show details" from [id:xxx] buttons injected into markdown bubbles
    messages.addEventListener('click', e => {
      const btn = e.target.closest('.chat-show-detail, [data-show-detail]');
      if (!btn) return;
      const docId = btn.dataset.docId ?? btn.dataset.hitId;
      if (docId) showDetail(docId, docId);
    });

     // Pre-load engine + template in background
     ensureTwigEngine().then(() => ensureTemplate());

     // Auto-submit ?q= querystring as the first message
     {% if initialQuery is defined and initialQuery %}
     input.value = {{ initialQuery|json_encode|raw }};
     setTimeout(() => send(), 100);
     {% endif %}
  })();
  </script>
{% endblock %}
