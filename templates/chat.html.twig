{#
  File: templates/chat.html.twig
  Meilisearch native chatCompletions UI — streams SSE from meili_chat_stream.
  Variables:
    indexName      - Meilisearch index UID
    baseIndexName  - registry base name
    workspace      - workspace name
    workspaceCfg   - workspace config array
    streamUrl      - POST endpoint for SSE stream
#}
{% extends "@SurvosMeili/base.html.twig" %}

{% block title %}Chat · {{ baseIndexName }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    body { background: #C4E0E5 !important; }

    .chat-shell {
      max-width: 860px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      height: calc(100vh - 120px);
    }

    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: .75rem;
    }

    .chat-bubble {
      max-width: 80%;
      padding: .65rem 1rem;
      border-radius: 1rem;
      line-height: 1.5;
      word-break: break-word;
    }
    .chat-bubble.user {
      align-self: flex-end;
      background: #0d6efd;
      color: #fff;
      border-bottom-right-radius: .25rem;
    }
    .chat-bubble.assistant {
      align-self: flex-start;
      background: #fff;
      border: 1px solid #dee2e6;
      border-bottom-left-radius: .25rem;
    }
    .chat-bubble.assistant.streaming::after {
      content: '▌';
      animation: blink .7s step-end infinite;
    }
    @keyframes blink { 50% { opacity: 0; } }

    .chat-bubble.error {
      align-self: flex-start;
      background: #f8d7da;
      border: 1px solid #f5c2c7;
      color: #842029;
    }

    /* Markdown content inside assistant bubbles */
    .chat-bubble.assistant p { margin: 0 0 .5rem; }
    .chat-bubble.assistant p:last-child { margin-bottom: 0; }
    .chat-bubble.assistant ul,
    .chat-bubble.assistant ol { margin: 0 0 .5rem; padding-left: 1.4rem; }
    .chat-bubble.assistant img {
      max-width: 100%;
      max-height: 220px;
      object-fit: contain;
      border-radius: .375rem;
      margin: .25rem 0;
      display: block;
    }
    .chat-bubble.assistant a {
      color: #0d6efd;
      text-decoration: underline;
    }
    .chat-bubble.assistant strong { font-weight: 600; }

    .chat-input-row {
      display: flex;
      gap: .5rem;
      padding: .75rem;
      background: rgba(255,255,255,.6);
      border-top: 1px solid #dee2e6;
      border-radius: 0 0 .5rem .5rem;
    }
    .chat-input-row textarea {
      flex: 1;
      resize: none;
      border-radius: .5rem;
      border: 1px solid #ced4da;
      padding: .5rem .75rem;
      font-size: .95rem;
      line-height: 1.4;
    }
    .chat-input-row button {
      align-self: flex-end;
    }

    /* Prompt debug panel */
    .chat-debug-panel {
      max-width: 860px;
      margin-left: auto;
      margin-right: auto;
      background: rgba(255,255,255,.7);
      border: 1px solid #dee2e6;
      border-radius: .5rem;
      font-size: .8rem;
    }
    .chat-debug-summary {
      cursor: pointer;
      padding: .5rem .75rem;
      font-weight: 600;
      color: #495057;
      user-select: none;
      list-style: none;
      display: flex;
      align-items: center;
      gap: .4rem;
    }
    .chat-debug-summary:hover { color: #0d6efd; }
    .chat-debug-summary::-webkit-details-marker { display: none; }
    .chat-debug-body {
      border-top: 1px solid #dee2e6;
      padding: .75rem;
      display: flex;
      flex-direction: column;
      gap: .75rem;
    }
    .chat-debug-prompt-label {
      font-size: .7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .05em;
      color: #6c757d;
      margin-bottom: .2rem;
    }
    .chat-debug-pre {
      background: #f8f9fa;
      border: 1px solid #e9ecef;
      border-radius: .375rem;
      font-size: .72rem;
      line-height: 1.5;
      margin: 0;
      padding: .5rem .75rem;
      white-space: pre-wrap;
      word-break: break-word;
    }

    /* Search debug note */
    .chat-search-note {
      font-size: .72rem;
      color: #6c757d;
      padding: .1rem 1rem;
      font-family: monospace;
    }
    .chat-search-note::before { content: '🔍 '; }

    /* Meilisearch sources JSON block */
    .chat-sources {
      max-width: 860px;
      margin: 0 1rem;
    }
    .chat-sources summary {
      cursor: pointer;
      font-size: .8rem;
      color: #6c757d;
      user-select: none;
      padding: .2rem 0;
    }
    .chat-sources summary:hover { color: #0d6efd; }
    .chat-sources-json {
      background: #f8f9fa;
      border: 1px solid #dee2e6;
      border-radius: .375rem;
      font-size: .72rem;
      line-height: 1.4;
      max-height: 320px;
      overflow: auto;
      padding: .75rem;
      white-space: pre;
      word-break: normal;
    }

    .chat-header {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      padding: .75rem 1rem;
      background: rgba(255,255,255,.6);
      border-radius: .5rem .5rem 0 0;
      border-bottom: 1px solid #dee2e6;
    }
  </style>
{% endblock %}

{% block body %}

{# ── prompt debug panel ──────────────────────────────────────────── #}
<details class="chat-debug-panel mt-2 mb-3" style="max-width:860px;margin-left:auto;margin-right:auto;">
  <summary class="chat-debug-summary">
    {{ ux_icon('mdi:bug-outline') }}
    Prompt debug — <code>{{ workspace }}</code> workspace · index <code>{{ indexName }}</code>
    {% if livePrompts is null %}
      <span class="badge bg-warning text-dark ms-2">Could not fetch live prompts</span>
    {% endif %}
  </summary>

  <div class="chat-debug-body">
    {% if livePrompts is null %}
      <div class="alert alert-warning mb-0">
        Could not retrieve prompts from Meilisearch workspace <code>{{ workspace }}</code>.
        Run <code>bin/console meili:settings:update --force</code> to push them.
      </div>
    {% else %}
      {% set promptKeys = {
        system:             'System',
        searchDescription:  'Search description',
        searchQParam:       'q param',
        searchFilterParam:  'filter param',
        searchIndexUidParam:'index UID param',
      } %}
      {% for key, label in promptKeys %}
        {% if livePrompts[key] is defined and livePrompts[key] %}
          <div class="chat-debug-prompt">
            <div class="chat-debug-prompt-label">{{ label }}</div>
            <pre class="chat-debug-pre">{{ livePrompts[key] }}</pre>
          </div>
        {% endif %}
      {% endfor %}
      {# Show any extra prompt keys not in the known set #}
      {% for key, value in livePrompts %}
        {% if key not in ['system','searchDescription','searchQParam','searchFilterParam','searchIndexUidParam'] and value %}
          <div class="chat-debug-prompt">
            <div class="chat-debug-prompt-label">{{ key }}</div>
            <pre class="chat-debug-pre">{{ value }}</pre>
          </div>
        {% endif %}
      {% endfor %}
    {% endif %}
  </div>
</details>

<div class="chat-shell mt-0 shadow rounded">

  {# ── header ─────────────────────────────────────────────────── #}
  <div class="chat-header">
    <strong>{{ baseIndexName }}</strong>
    <span class="text-muted small">workspace: {{ workspace }}</span>
    <div class="ms-auto d-flex gap-2">
      <a href="{{ path('meili_insta', {indexName: baseIndexName}) }}"
         class="btn btn-sm btn-outline-secondary">
        {{ ux_icon('search') }} Search
      </a>
    </div>
  </div>

  {# ── message list ────────────────────────────────────────────── #}
  <div class="chat-messages" id="chat-messages">
    <div class="chat-bubble assistant">
      Hi! Ask me anything about the <strong>{{ baseIndexName }}</strong> data.
    </div>
  </div>

  {# ── input row ───────────────────────────────────────────────── #}
  <div class="chat-input-row">
    <textarea id="chat-input"
              rows="2"
              placeholder="Ask a question…"
              autofocus></textarea>
    <button id="chat-send" class="btn btn-primary">
      Send
    </button>
  </div>

</div>
{% endblock body %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <script>
  (function () {
    const streamUrl  = {{ streamUrl|json_encode|raw }};
    const messages   = document.getElementById('chat-messages');
    const input      = document.getElementById('chat-input');
    const sendBtn    = document.getElementById('chat-send');

    // Configure marked: sanitize links, open in new tab
    marked.use({
      breaks: true,
      gfm: true,
    });

    // Conversation history kept client-side so Meilisearch sees context.
    // _meiliAppendConversationMessage events add internal tool messages here too.
    const history = [];

    function scrollBottom() {
      messages.scrollTop = messages.scrollHeight;
    }

    function addBubble(role, text) {
      const div = document.createElement('div');
      div.className = 'chat-bubble ' + role;
      div.textContent = text;
      messages.appendChild(div);
      scrollBottom();
      return div;
    }

    /** Render accumulated markdown into the bubble and make links open in new tab. */
    function renderMarkdown(bubble, markdown) {
      bubble.innerHTML = marked.parse(markdown);
      bubble.querySelectorAll('a').forEach(a => {
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
      });
    }

    /** Render source documents as a collapsible JSON block below the bubble. */
    function addSourcesBlock(documents) {
      const details = document.createElement('details');
      details.className = 'chat-sources mt-2';
      const summary = document.createElement('summary');
      summary.textContent = `Meilisearch sources (${Array.isArray(documents) ? documents.length : Object.keys(documents).length} hits)`;
      const pre = document.createElement('pre');
      pre.className = 'chat-sources-json';
      pre.textContent = JSON.stringify(documents, null, 2);
      details.appendChild(summary);
      details.appendChild(pre);
      messages.appendChild(details);
      scrollBottom();
    }

    async function send() {
      const text = input.value.trim();
      if (!text) return;

      input.value = '';
      input.disabled = true;
      sendBtn.disabled = true;

      addBubble('user', text);
      history.push({ role: 'user', content: text });

      const bubble = addBubble('assistant', '');
      bubble.classList.add('streaming');
      let reply = '';

      // Accumulate streamed tool call arguments by tool call index
      const toolCalls = {};

      try {
        const resp = await fetch(streamUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history }),
        });

        if (!resp.ok) {
          bubble.classList.remove('streaming');
          bubble.classList.add('error');
          bubble.textContent = 'Error: ' + resp.status + ' ' + resp.statusText;
          return;
        }

        const reader = resp.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });

          // SSE: split on double-newline, process each event
          const parts = buffer.split('\n\n');
          buffer = parts.pop(); // keep incomplete tail

          for (const part of parts) {
            for (const line of part.split('\n')) {
              if (!line.startsWith('data:')) continue;
              const data = line.slice(5).trim();
              if (data === '[DONE]') continue;
              try {
                const parsed = JSON.parse(data);

                // Accumulate streamed tool call argument fragments
                for (const tc of parsed?.choices?.[0]?.delta?.tool_calls ?? []) {
                  const idx = tc.index ?? 0;
                  if (!toolCalls[idx]) {
                    toolCalls[idx] = { id: tc.id ?? '', name: tc.function?.name ?? '', args: '' };
                  }
                  if (tc.function?.name)      toolCalls[idx].name = tc.function.name;
                  if (tc.id)                  toolCalls[idx].id   = tc.id;
                  if (tc.function?.arguments) toolCalls[idx].args += tc.function.arguments;
                }

                // finish_reason === 'tool_calls': process all accumulated tool calls
                if (parsed?.choices?.[0]?.finish_reason === 'tool_calls') {
                  for (const tc of Object.values(toolCalls)) {
                    let args = {};
                    try { args = JSON.parse(tc.args); } catch (_) {}

                    if (tc.name === '_meiliSearchProgress') {
                      // Show which index was actually searched — key debug info
                      try {
                        const params = JSON.parse(args.function_parameters ?? '{}');
                        if (params.index_uid) {
                          const note = document.createElement('div');
                          note.className = 'chat-search-note';
                          note.textContent = `Searched: ${params.index_uid}${params.q ? ' · q: "' + params.q + '"' : ''}`;
                          messages.appendChild(note);
                          scrollBottom();
                        }
                      } catch (_) {}
                    } else if (tc.name === '_meiliSearchSources') {
                      addSourcesBlock(args.documents ?? args);
                    } else if (tc.name === '_meiliAppendConversationMessage') {
                      // Maintain conversation context as Meilisearch requests
                      const msg = { role: args.role };
                      if (args.tool_calls) msg.tool_calls = args.tool_calls;
                      if (args.content)    msg.content    = args.content;
                      if (args.tool_call_id) msg.tool_call_id = args.tool_call_id;
                      history.push(msg);
                    }
                    // _meiliSearchProgress: no UI action needed (search is already done)
                  }
                }

                const delta = parsed?.choices?.[0]?.delta?.content ?? '';
                if (delta) {
                  reply += delta;
                  // During streaming show plain text (fast, no partial-markdown glitches)
                  bubble.textContent = reply;
                  scrollBottom();
                }
                // handle error object returned by our proxy
                if (parsed?.error) {
                  bubble.classList.add('error');
                  bubble.textContent = parsed.error;
                }
              } catch (_) { /* non-JSON line, skip */ }
            }
          }
        }
      } catch (err) {
        bubble.classList.add('error');
        bubble.textContent = 'Connection error: ' + err.message;
      } finally {
        bubble.classList.remove('streaming');
        if (reply) {
          // Render markdown now that the full reply is available
          renderMarkdown(bubble, reply);
          history.push({ role: 'assistant', content: reply });
        }
        input.disabled = false;
        sendBtn.disabled = false;
        input.focus();
        scrollBottom();
      }
    }

    sendBtn.addEventListener('click', send);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        send();
      }
    });
  })();
  </script>
{% endblock %}
