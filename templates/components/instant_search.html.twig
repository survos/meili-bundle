{% set _sc = this.stimulusController %}
{% set _sc_modal = this.modalStimulusController %}
{% set debug = app.request.query.get('debug', false) %}
{% set cols = app.request.query.get('cols') ?? app.request.query.get('grid') ?? 2 %}
{% set templateUrl = path('meili_template', { templateName: this.templateName }) %}
{% set globals = {
    serverUrl: this.server,
    serverApiKey: this.apiKey,
    indexName: this.indexName,
    baseIndexName: this.baseIndexName,
    _sc_modal: _sc_modal,
    imgproxyHost: this.imgproxyHost|default(false),
    debug: debug,
    chatBaseUrl: path('meili_chat', {indexName: 'INDEXNAME', workspace: 'meili_assistant'}),
    searchBaseUrl: path('meili_insta', {indexName: 'INDEXNAME'})
} %}
{% set icons = {
    json: ux_icon('si:json-duotone'),
    bug: ux_icon('tabler:bug'),
    wikidata: ux_icon('openmoji:wikidata'),
    website: ux_icon('fluent-mdl2:website'),
    facebook: ux_icon('mdi:facebook')
} %}

<div
    {{ stimulus_controller(_sc, {
        serverUrl: this.server,
        serverApiKey: this.apiKey,
        indexName: this.indexName,
        sanity: app.request.query.get('sanity', true),
        embedderName: this.embedder,
        hitClass: 'grid-' ~ cols,
        sortingJson: this.sorting|json_encode,
        globalsJson: globals|json_encode,
        iconsJson: icons|json_encode,
        configJson: this.indexConfig|json_encode,
        templateUrl: templateUrl,
        q: this.q,
        searchAsYouType: this.searchAsYouType ? true : false,
        scoreThreshold: app.request.query.get('minScore')|default(0)
    }) }}
    class="survos-meili-instant-search container-fluid px-0 py-3"
>
    <div class="insta-grid row" {{ stimulus_controller(_sc_modal, {
        serverUrl: this.server,
        serverApiKey: this.apiKey,
        indexName: this.indexName,
        globalsJson: globals|json_encode
    }) }}>
        {{ include('@SurvosMeili/components/_modal.html.twig', { _sc_modal: _sc_modal }) }}

        {% if this.embedder %}
            <div style="display:none" {{ stimulus_target(_sc, 'refinementList') }}></div>
            <main class="col-12">
                <div class="mb-3 d-flex gap-2 align-items-center">
                    <div class="flex-grow-1" {{ stimulus_target(_sc, 'searchBox') }}></div>
                    <button type="button"
                            class="btn btn-primary"
                            title="Run search"
                            {{ stimulus_target(_sc, 'submit') }}
                            {{ stimulus_action(_sc, 'submit', 'click') }}
                            style="{{ this.searchAsYouType ? 'display:none' : '' }}">
                        Search
                    </button>
                    <div {{ stimulus_target(_sc, 'reset') }}></div>
                </div>
                <div class="mb-2 small text-muted" {{ stimulus_target(_sc, 'stats') }}></div>
                <div class="mb-2" {{ stimulus_target(_sc, 'notice') }}></div>
                <div {{ stimulus_target(_sc, 'hits') }} style="--cols: {{ cols|e('html_attr') }};"></div>
                <div class="mt-4 d-none" {{ stimulus_target(_sc, 'pagination') }}></div>
            </main>
        {% else %}
            <aside id="facets-sidebar" class="col-12 col-md-4 col-lg-3 offcanvas-md offcanvas-start" aria-label="Filters" tabindex="-1" {{ stimulus_target(_sc, 'refinementList facetsSidebar') }}>
                <div class="offcanvas-header p-3 p-md-0">
                    <h5 class="offcanvas-title">Filters</h5>
                    <button type="button" class="btn-close" {{ stimulus_action(_sc, 'hideFacetsSidebar', 'click') }}></button>
                </div>
                <div class="offcanvas-body p-3 p-md-0">
                    <div class="w-100">
                        {% for name, conf in this.indexConfig.facets ?? {} %}
                            {% set widget = conf.widget ?? conf.type ?? 'RefinementList' %}
                            <div class="facet-block mb-3" data-facet-block>
                                <div class="facet-header d-flex align-items-center gap-2">
                                    <h3 class="facet-title h6 m-0 flex-grow-1">{{ conf.label ?? name }}</h3>
                                    <button class="facet-collapse btn btn-ghost btn-sm p-0"
                                            type="button"
                                            data-collapse-control
                                            data-attribute="{{ name }}"
                                            aria-expanded="{{ (conf.collapsed is same as(true)) ? 'false' : 'true' }}"
                                            title="Collapse/Expand">
                                        {{ ux_icon('tabler:chevron-down')|raw }}
                                    </button>
                                </div>
                                <div class="facet-body mt-2">
                                    <div
                                        data-attribute="{{ name }}"
                                        data-search-mode="{{ conf.searchMode|default('contains') }}"
                                        data-widget="{{ widget }}"
                                        {% if conf.sortMode is defined %} data-sort-mode="{{ conf.sortMode }}"{% endif %}
                                        {% if conf.searchable is same as(true) %} data-searchable="true"{% elseif conf.searchable is same as(false) %} data-searchable="false"{% endif %}
                                        {% if conf.limit is defined and conf.limit is not null %} data-limit="{{ conf.limit }}"{% endif %}
                                        {% if conf.showMoreLimit is defined and conf.showMoreLimit is not null %} data-show-more-limit="{{ conf.showMoreLimit }}"{% endif %}
                                        {% if conf.lookup is defined and conf.lookup is iterable %} data-lookup='{{ conf.lookup|json_encode }}'{% endif %}
                                        {% if widget == 'RangeSlider' %}
                                            {% if conf.step is defined %} data-step="{{ conf.step }}"{% endif %}
                                            {% if conf.min is defined %} data-min="{{ conf.min }}"{% endif %}
                                            {% if conf.max is defined %} data-max="{{ conf.max }}"{% endif %}
                                            {% if conf.pips is defined %} data-pips="{{ conf.pips ? 'true' : 'false' }}"{% endif %}
                                            {% if conf.tooltips is defined %} data-tooltips='{{ conf.tooltips|json_encode }}'{% endif %}
                                        {% endif %}
                                    ></div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </aside>

            <main class="col-12 col-md-8 col-lg-9">
                <div class="mb-3 d-flex align-items-center gap-2">
                    <div class="flex-grow-1" {{ stimulus_target(_sc, 'searchBox') }}></div>
                    <button type="button"
                            class="btn btn-primary"
                            title="Run search"
                            {{ stimulus_target(_sc, 'submit') }}
                            {{ stimulus_action(_sc, 'submit', 'click') }}
                            style="{{ this.searchAsYouType ? 'display:none' : '' }}">
                        Search
                    </button>
                    <div {{ stimulus_target(_sc, 'reset') }}></div>
                    {% if this.chatWorkspace %}
                        <a href="{{ path('meili_chat', {indexName: this.baseIndexName, workspace: this.chatWorkspace}) }}" class="btn btn-info text-white">
                            {{ ux_icon('heroicons:chat-bubble-left-right') }} Chat
                        </a>
                    {% endif %}
                </div>
                <div class="mb-2 d-flex gap-2 align-items-center justify-content-between">
                    <div class="small text-muted" {{ stimulus_target(_sc, 'stats') }}></div>
                    <div {{ stimulus_target(_sc, 'sortBy') }}></div>
                </div>
                <div class="mb-2" {{ stimulus_target(_sc, 'notice') }}></div>
                <div {{ stimulus_target(_sc, 'hits') }} style="--cols: {{ cols|e('html_attr') }};"></div>
                <div class="mt-4" {{ stimulus_target(_sc, 'pagination') }}></div>
            </main>

            <button class="btn btn-dark d-md-none btn-show-facets-sidebar" {{ stimulus_action(_sc, 'showFacetsSidebar', 'click') }}>
                {{ ux_icon('heroicons:adjustments-horizontal') }} Show Filters
            </button>
        {% endif %}

        <div {{ stimulus_target(_sc, 'detailPanel') }} class="offcanvas offcanvas-end" tabindex="-1" style="width: min(600px, 95vw);">
            <div class="offcanvas-header border-bottom">
                <h5 class="offcanvas-title" {{ stimulus_target(_sc, 'detailPanelTitle') }}></h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body p-0" {{ stimulus_target(_sc, 'detailPanelBody') }}>
                <div class="d-flex justify-content-center align-items-center h-100 text-muted py-5" {{ stimulus_target(_sc, 'detailPanelLoader') }}>
                    <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                    Loading...
                </div>
            </div>
        </div>
    </div>
</div>
