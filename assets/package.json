{
  "name": "@survos/meili",
  "description": "integrate meili and instant search.  NOTE: flag-icons:^7.5 removed from importmap and flag-icons/css/flag-icons.min.css removed from autoimport",
  "license": "MIT",
  "version": "1.1",
  "symfony": {
    "controllers": {
      "insta": {
        "main": "src/controllers/insta_controller.js",
        "webpackMode": "eager",
        "fetch": "eager",
        "enabled": true,
        "autoimport": {
          "instantsearch.css/themes/algolia.min.css": false,
          "pretty-print-json/dist/css/pretty-print-json.min.css": true
        }
      },
      "json": {
        "main": "src/controllers/json_controller.js",
        "webpackMode": "eager",
        "fetch": "lazy",
        "enabled": true,
        "autoimport": {}
      },
      "chat": {
        "main": "src/controllers/chat_controller.js",
        "webpackMode": "eager",
        "fetch": "lazy",
        "enabled": true,
        "autoimport": {
          "@survos/meili/styles/chat.css": true
        }
      }
    },
    "importmap": {
      "@tacman1123/twig-browser": "^0.4.18",
      "debug": "^4.4.3",
      "instantsearch.js": "^4.92.1",
      "instantsearch.js/es/widgets": "^4.92.1",
      "instantsearch.css/themes/algolia.min.css": "^8.12.0",
      "@meilisearch/instant-meilisearch": "^0.30.0",
      "@stimulus-components/dialog": "*",
      "meilisearch": "*",
      "@andypf/json-viewer": "^2.3.2",
      "pretty-print-json": "^3.0.7"
    }
  },
  "peerDependencies": {
    "@hotwired/stimulus": "^3.2.2"
  },
  "devDependencies": {
    "@hotwired/stimulus": "^3.2.2"
  },
  "dependencies": {
    "@tacman1123/twig-browser": "^0.4.18",
    "@tabler/core": "^1.4.0",
    "instantsearch.css": "^8.12.0"
  }
}
